name: Update Combined Economist RSS

on:
  schedule:
    - cron: "0 * * * *"  # Every hour
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-lates
    permissions:
      contents: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install Python dependencies
        run: |
          python -m pip install --upgrade pip
          # Install dependencies required by lau.py
          pip install feedparser beautifulsoup4 requests playwright

      - name: Install Playwright
        run: |
          playwright install chromium
          playwright install-deps chromium

      - name: Install BotBrowser & Profile
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          # 1. Fetch Release Info
          echo "Fetching latest BotBrowser release info..."
          RELEASE_JSON=$(curl -s -H "Authorization: Bearer $GH_TOKEN" https://api.github.com/repos/MiddleSchoolStudent/BotBrowser/releases/latest)
          
          # 2. Find and Download .deb (x64/amd64)
          DEB_URL=$(echo "$RELEASE_JSON" | jq -r '.assets[] | select(.name | endswith(".deb")) | select(.name | contains("amd64") or contains("x64")) | .browser_download_url' | head -n 1)
          
          if [ -z "$DEB_URL" ] || [ "$DEB_URL" = "null" ]; then
            echo "❌ Error: Could not find compatible .deb asset."
            exit 1
          fi
          
          echo "Downloading BotBrowser: $DEB_URL"
          curl -L -H "Authorization: Bearer $GH_TOKEN" "$DEB_URL" -o botbrowser.deb
          sudo dpkg -i botbrowser.deb || sudo apt-get install -f -y

          # 3. Locate Binary
          BB_BIN=""
          for candidate in /usr/bin/botbrowser /opt/botbrowser/botbrowser /usr/bin/chromium-browser-stable; do
            if [ -x "$candidate" ]; then
              BB_BIN="$candidate"
              break
            fi
          done
          
          if [ -z "$BB_BIN" ]; then
            echo "❌ Error: BotBrowser binary not found after installation."
            exit 1
          fi
          
          echo "BotBrowser installed at: $BB_BIN"
          echo "BOTBROWSER_PATH=$BB_BIN" >> $GITHUB_ENV

          # 4. Find and Download Profile (if available)
          PROFILE_URL=$(echo "$RELEASE_JSON" | jq -r '.assets[] | select(.name | endswith(".zip")) | select(.name | contains("profile")) | .browser_download_url' | head -n 1)
          
          if [ -n "$PROFILE_URL" ] && [ "$PROFILE_URL" != "null" ]; then
            echo "Downloading Profile: $PROFILE_URL"
            curl -L -H "Authorization: Bearer $GH_TOKEN" "$PROFILE_URL" -o profile.zip
            unzip -o profile.zip
            
            # Find the .enc file inside
            PROFILE_FILE=$(find . -maxdepth 1 -name "*.enc" | head -n 1)
            if [ -n "$PROFILE_FILE" ]; then
               REAL_PATH=$(realpath "$PROFILE_FILE")
               echo "Using profile: $REAL_PATH"
               echo "BOTBROWSER_PROFILE=$REAL_PATH" >> $GITHUB_ENV
            fi
          else
            echo "⚠️ No profile found in assets. Running without profile."
          fi

      - name: Run combined RSS script
        env:
          BOTBROWSER_CDP_PORT: "9222"
          # PYTHONUNBUFFERED ensures logs print immediately
          PYTHONUNBUFFERED: "1"
        run: |
          # Run the script with a timeout to prevent hanging workflows
          timeout 1800 python lau.py

      - name: Check file generation
        run: |
          if [ -f combined.xml ]; then
            echo "✓ RSS file generated successfully"
            grep -c '<item>' combined.xml || echo "0 items found"
          else
            echo "❌ RSS file not found"
            exit 1
          fi

      - name: Commit and push changes
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          
          git add combined.xml
          
          # Add debug files if they exist (generated by lau.py on failure)
          git add debug_*.html 2>/dev/null || true

          if git diff --staged --quiet; then
            echo "No changes to commit"
          else
            git commit -m "Auto-update combined Economist RSS [$(date -u +'%Y-%m-%d %H:%M:%S UTC')]"
            git push
          fi
      
      - name: Upload debug artifacts on failure
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: debug-files
          path: |
            debug_*.html
            *.log
          retention-days: 3
